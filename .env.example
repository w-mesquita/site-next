# URL base da API Gestly (gestly-site-api).
# Desenvolvimento: site na 3000, API na 3001. Produção: ex. https://sua-api.railway.app
NEXT_PUBLIC_GESTLY_API_URL=http://localhost:3001

# Domínio do site para a API (identifica qual site carregar/salvar). Ex.: localhost:3000 em dev.
NEXT_PUBLIC_SITE_DOMAIN=localhost:3000
